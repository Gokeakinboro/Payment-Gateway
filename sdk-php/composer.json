{
  "name": "paylode/paylode-php",
  "description": "Official PHP SDK for Paylode Services Limited — CBN Licensed PSSP",
  "version": "1.0.0",
  "type": "library",
  "keywords": ["paylode", "payments", "nigeria", "fintech", "cbn", "pssp", "payment-gateway"],
  "homepage": "https://docs.paylodeservices.com",
  "license": "MIT",
  "authors": [
    {
      "name": "Paylode Services Limited",
      "email": "dev@paylodeservices.com",
      "homepage": "https://paylodeservices.com"
    }
  ],
  "require": {
    "php": ">=7.4",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Paylode\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Paylode\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit tests/"
  },
  "support": {
    "issues": "https://github.com/Gokeakinboro/Payment-Gateway/issues",
    "source": "https://github.com/Gokeakinboro/Payment-Gateway"
  },
  "minimum-stability": "stable"
}
