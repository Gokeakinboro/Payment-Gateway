# ─── Paylode Backend — Environment Variables ────────────────────────────────
# Copy to .env and fill in your values
# NEVER commit .env to git

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://paylode:CHANGE_ME@localhost:5432/paylode_db"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=https://paylodeservices.com
API_URL=https://api.paylodeservices.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_64_RANDOM_CHARS
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=CHANGE_ME_ANOTHER_64_RANDOM_CHARS
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=CHANGE_ME
EMAIL_FROM=noreply@paylodeservices.com
EMAIL_SUPPORT=support@paylodeservices.com

# ── File Storage (Cloudflare R2 or AWS S3) ───────────────────────────────────
S3_BUCKET=paylode-kyc-docs
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# ── Encryption (for settlement account numbers) ──────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX_64_CHARS

# ── Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_MS=30000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── CBN / Compliance ──────────────────────────────────────────────────────────
CBN_LICENSE_NO=CBN/PAY/2024/001847
COMPLIANCE_EMAIL=compliance@paylodeservices.com

# ── KYC Verification APIs (connect when ready) ───────────────────────────────
# NIBSS_BVN_BASE_URL=https://api.nibss-plc.com.ng
# NIBSS_BVN_API_KEY=CHANGE_ME
# VERIFYME_API_KEY=CHANGE_ME
# SMILEID_API_KEY=CHANGE_ME

# ── Parallex Bank — Virtual Account (pay-in / collections) ───────────────────
# Adapter dormant until USERNAME+PASSWORD+SUBKEY set. VA password is BASE64'd by
# the adapter — put it PLAINTEXT here. (working sandbox values below)
# PARALLEX_VA_BASE_URL=https://parallex-apim.azure-api.net/VirtualAccount/v1/VirtualAccount
# PARALLEX_VA_USERNAME=PaylodeVirtualA
# PARALLEX_VA_PASSWORD=Password@1234
# PARALLEX_VA_SUBKEY=CHANGE_ME_VA_SUBSCRIPTION_KEY
# PARALLEX_VA_MERCHANT_ID=PB_015
# PARALLEX_VA_WEBHOOK_SECRET=          # set to ENFORCE inflow verification (else scaffold-accept)

# ── Parallex Bank — Third Party Transfer (payout rail) ───────────────────────
# Adapter dormant until USERNAME+PASSWORD+SUBKEY set. Transfer password is
# PLAINTEXT (NOT base64), and the subkey DIFFERS from the VA one.
# PARALLEX_TRANSFER_BASE_URL=https://parallex-apim.azure-api.net/thirdpartytransfer
# PARALLEX_TRANSFER_USERNAME=PayloadeVirtualAcc     # note the typo — this is the working sandbox username
# PARALLEX_TRANSFER_PASSWORD=Password@1234
# PARALLEX_TRANSFER_SUBKEY=CHANGE_ME_TRANSFER_SUBSCRIPTION_KEY
# PARALLEX_TRANSFER_DEBIT_ACCOUNT=2001096025        # our settlement/debit account (accountToDebit)
# PARALLEX_TRANSFER_BANK_CODE=999015                # Parallex's own institution code (intra vs inter)
# PARALLEX_TRANSFER_LOCATION=Lagos
