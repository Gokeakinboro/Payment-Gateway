{
  "name": "paylode-backend",
  "version": "1.0.0",
  "description": "Paylode Services Limited — Payment Gateway Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:core": "node src/entrypoints/core.js",
    "start:invoicing": "node src/entrypoints/invoicing.js",
    "start:wallet": "node src/entrypoints/wallet.js",
    "start:assistant": "node src/entrypoints/assistant.js",
    "pm2:split": "pm2 start ecosystem.config.js",
    "verify:arch": "node tools/resolve-requires.js && node tools/route-parity.js && node tools/p3-split-check.js && node tools/guard-selftest.js && node tools/db-boundary-check.js",
    "db:migrate": "npx prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "cloudinary": "^2.10.0",
    "otplib": "^13.4.1",
    "pdfkit": "^0.18.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "web-push": "^3.6.7",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "pino": "^9.1.0",
    "pino-pretty": "^11.1.0",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "prisma": "^5.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
